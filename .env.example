# Copy to .env and adjust. All values are optional; defaults shown.

# Directory to index when a tool call omits an explicit path. Leave unset to
# default to the process working directory (the repo Claude Code launched in) —
# this is what makes a single user-scoped server work from any repo.
# ROOT_PATH=.

# Central cache dir. Holds one DB per indexed repo (keyed by repo path), so the
# server can be shared across repos without collisions. Defaults to ~/.graph-memory.
# DATA_DIR=~/.graph-memory

# Comma/JSON list of languages to index (must have a grammar installed).
# LANGUAGES=["python","typescript","javascript"]

# Skip files larger than this many bytes (usually generated/minified).
MAX_FILE_BYTES=1000000

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
